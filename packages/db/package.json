{
  "name": "@yomikiri/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./schema": {
      "types": "./src/schema.ts",
      "default": "./src/schema.ts"
    },
    "./client-serverless": {
      "types": "./src/client-serverless.ts",
      "default": "./src/client-serverless.ts"
    },
    "./client-node": {
      "types": "./src/client-node.ts",
      "default": "./src/client-node.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "generate": "drizzle-kit generate",
    "migrate": "tsx scripts/migrate.ts",
    "seed": "tsx scripts/seed.ts"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9"
  }
}
