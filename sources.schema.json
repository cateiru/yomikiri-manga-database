{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/cateiru/yomikiri-manga-database/sources.schema.json",
  "title": "Sources",
  "description": "クロール対象サービスの定義",
  "type": "object",
  "required": ["sources"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "sources": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/source"
      }
    }
  },
  "definitions": {
    "source": {
      "type": "object",
      "required": ["key", "name", "listUrls", "siteUrl", "parser", "enabled", "favicon"],
      "additionalProperties": false,
      "properties": {
        "key": {
          "type": "string",
          "minLength": 1,
          "description": "サービスの一意なキー。DB の source_key に保存する"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "表示用のサービス名"
        },
        "listUrls": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri"
          },
          "minItems": 1,
          "description": "クロール対象の一覧ページ URL（同じ parser で解析し、同じ source.key で登録する）"
        },
        "siteUrl": {
          "type": "string",
          "format": "uri",
          "description": "サービスのトップページ URL。詳細取得バッチでの robots.txt 取得元、/about ページ等での紹介リンクに使用する"
        },
        "favicon": {
          "type": "string",
          "pattern": "^/favicons/.+\\.png$",
          "description": "apps/web/public 以下に配置した favicon 画像への絶対パス"
        },
        "parser": {
          "type": "string",
          "enum": ["gigaviewer", "magapoke", "comic-walker", "comici"],
          "description": "使用するパーサー種別"
        },
        "enabled": {
          "type": "boolean",
          "description": "false にするとクロール対象から除外する"
        },
        "fallbackSourceKey": {
          "type": "string",
          "minLength": 1,
          "description": "指定した source.key に既に同一パスの viewer URL が登録済みの場合、このソースでの登録をスキップする（姉妹サイト等での重複防止用）"
        }
      }
    }
  }
}
